# --- LLM (free Gemini tier, called over REST) ---
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
GEMINI_API_KEY=your-gemini-key-from-aistudio

# --- Data source ---
# TODAY: read a local file (the HR Excel you downloaded works as-is)
SOURCE_TYPE=local
DATA_PATH=HR_Staff_Data.xlsx
TABLE_NAME=staff

# LATER: read live from SharePoint via Microsoft Graph
# SOURCE_TYPE=sharepoint
# GRAPH_TOKEN=delegated-graph-token-scope-Files.Read.All
# SHAREPOINT_FILE_URL=https://graph.microsoft.com/v1.0/drives/<driveId>/items/<itemId>/content
